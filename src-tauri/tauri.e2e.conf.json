{
  "$schema": "https://schema.tauri.app/config/2",
  "app": {
    "withGlobalTauri": true,
    "windows": [{ "incognito": true }],
    "security": {
      "capabilities": [
        {
          "identifier": "e2e",
          "windows": ["main"],
          "permissions": [
            "core:default",
            "process:allow-restart",
            "updater:default",
            "wdio:default",
            "wdio-webdriver:default"
          ]
        }
      ]
    }
  }
}
