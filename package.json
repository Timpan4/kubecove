{
  "name": "kubecove",
  "private": true,
  "version": "0.7.1",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:bundled": "KUBECOVE_VITE_BUNDLED_DEV=1 vite",
    "tauri:dev:bundled": "KUBECOVE_VITE_BUNDLED_DEV=1 bun run tauri dev",
    "tauri:dev-server": "bun scripts/tauri-dev-server.ts",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "bun test",
    "bench": "vitest bench --run",
    "typecheck": "tsc --noEmit",
    "svelte:check": "node scripts/svelte-check-with-typescript6.cjs --no-tsconfig --ignore \"src/features/resources/topology-spike\"",
    "lint": "biome lint .",
    "doctor": "svelte-doctor . --offline --no-analytics --no-dead-code",
    "doctor:ci": "svelte-doctor . --offline --no-analytics --no-dead-code",
    "doctor:score": "svelte-doctor . --score --offline --no-analytics --no-dead-code",
    "perf:frontend": "bun scripts/perf-frontend.ts",
    "perf:resource-scope": "bun scripts/perf-resource-scope.ts",
    "rust:bench": "cargo bench --manifest-path src-tauri/Cargo.toml --features bench-support --bench backend_hot_paths",
    "rust:test": "cargo test --manifest-path src-tauri/Cargo.toml",
    "rust:check": "cargo check --manifest-path src-tauri/Cargo.toml",
    "rust:lint": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets --all-features -- -D warnings",
    "check": "bun run typecheck && bun run svelte:check && bun run lint && bun test && bun run rust:test && bun run rust:check && bun run rust:lint",
    "version:bump": "bun scripts/bump-version.ts",
    "release:prepare": "bun scripts/prepare-release-pr.ts",
    "release:check": "bun scripts/release-beta.ts check",
    "release:dry-run": "bun scripts/release-beta.ts dry-run",
    "release": "bun scripts/release-beta.ts release"
  },
  "dependencies": {
    "@codemirror/lang-yaml": "6.1.3",
    "@codemirror/language": "6.12.3",
    "@codemirror/lint": "6.9.7",
    "@codemirror/state": "6.7.0",
    "@codemirror/view": "6.43.2",
    "@fontsource-variable/geist": "5.2.9",
    "@fontsource-variable/inter": "5.2.8",
    "@lezer/highlight": "1.2.3",
    "@tanstack/svelte-query": "6.1.36",
    "@tauri-apps/api": "2.11.1",
    "@tauri-apps/plugin-process": "2.3.1",
    "@tauri-apps/plugin-updater": "2.10.1",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/xterm": "6.0.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "diff": "9.0.0",
    "tailwind-merge": "3.6.0",
    "yaml": "2.9.0",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@codspeed/vitest-plugin": "^5.7.1",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@framework-doctor/svelte": "1.0.4",
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "@tailwindcss/vite": "4.3.1",
    "@tauri-apps/cli": "2.11.3",
    "@xyflow/svelte": "1.6.1",
    "bits-ui": "2.18.1",
    "fast-check": "4.8.0",
    "lucide-svelte": "1.0.1",
    "playwright-core": "1.61.1",
    "svelte": "5.56.4",
    "svelte-check": "4.7.1",
    "tailwindcss": "4.3.1",
    "tw-animate-css": "1.4.0",
    "typescript": "6.0.3",
    "typescript-6": "npm:typescript@6.0.3",
    "vite": "8.1.2",
    "vitest": "^4.1.9"
  }
}
