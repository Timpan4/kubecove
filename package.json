{
  "name": "kubecove",
  "private": true,
  "version": "0.3.0",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "tauri:dev-server": "bun scripts/tauri-dev-server.ts",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "doctor": "react-doctor .",
    "doctor:ci": "react-doctor . --fail-on error --annotations",
    "doctor:score": "react-doctor . --score --fail-on none",
    "rust:test": "cargo test --manifest-path src-tauri/Cargo.toml",
    "rust:check": "cargo check --manifest-path src-tauri/Cargo.toml",
    "check": "bun run typecheck && bun test && bun run rust:test && bun run rust:check",
    "version:bump": "bun scripts/bump-version.ts",
    "release:check": "bun scripts/release-beta.ts check",
    "release:dry-run": "bun scripts/release-beta.ts dry-run",
    "release": "bun scripts/release-beta.ts release"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/inter": "^5.2.8",
    "@tanstack/react-query": "^5.100.9",
    "@tanstack/react-router": "^1.169.2",
    "@tanstack/react-table": "^8.21.3",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@xyflow/react": "^12.10.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-resizable-panels": "^4.11.1",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.3.0",
    "@tauri-apps/cli": "^2.11.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "fast-check": "^4.8.0",
    "react-doctor": "0.2.9",
    "tailwindcss": "4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "~6.0.3",
    "vite": "^8.0.10"
  }
}
