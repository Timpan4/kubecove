{
  "name": "kubecove",
  "private": true,
  "version": "0.9.1",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "dev": "bunx --bun vite",
    "tauri:dev-server": "bun scripts/tauri-dev-server.ts",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "bun scripts/tauri.ts",
    "test": "bun test",
    "bench": "vitest bench --run",
    "typecheck": "tsc --noEmit",
    "svelte:check": "node scripts/svelte-check-with-typescript6.cjs --no-tsconfig --ignore \"src/features/resources/topology-spike\"",
    "lint": "biome lint .",
    "audit": "bun audit --audit-level=high",
    "perf:frontend": "bun scripts/perf-frontend.ts",
    "perf:resource-scope": "bun scripts/perf-resource-scope.ts",
    "rust:bench": "cargo bench --manifest-path src-tauri/Cargo.toml --features bench-support --bench backend_hot_paths",
    "rust:test": "cargo test --manifest-path src-tauri/Cargo.toml",
    "rust:check": "cargo check --manifest-path src-tauri/Cargo.toml",
    "rust:lint": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets --all-features -- -D warnings",
    "check": "bun run typecheck && bun run svelte:check && bun run lint && bun test && bun run rust:test && bun run rust:check && bun run rust:lint",
    "version:bump": "bun scripts/bump-version.ts",
    "release:prepare": "bun scripts/prepare-release-pr.ts",
    "release:check": "bun scripts/release-beta.ts check",
    "release:dry-run": "bun scripts/release-beta.ts dry-run",
    "release": "bun scripts/release-beta.ts release",
    "e2e:fast": "bun e2e/lifecycle.ts fast",
    "e2e:real": "bun e2e/lifecycle.ts run",
    "e2e:cleanup": "bun e2e/lifecycle.ts cleanup",
    "e2e:desktop-smoke": "bun e2e/lifecycle.ts desktop-smoke",
    "dev:kind": "bun e2e/lifecycle.ts dev-up",
    "dev:kind:down": "bun e2e/lifecycle.ts dev-down"
  },
  "dependencies": {
    "@codemirror/lang-yaml": "6.1.3",
    "@codemirror/language": "6.12.4",
    "@codemirror/lint": "6.9.7",
    "@codemirror/state": "6.7.1",
    "@codemirror/view": "6.43.6",
    "@fontsource-variable/geist": "5.3.0",
    "@fontsource-variable/inter": "5.3.0",
    "@lezer/highlight": "1.2.3",
    "@tanstack/svelte-query": "6.1.37",
    "@tauri-apps/api": "2.11.1",
    "@tauri-apps/plugin-process": "2.3.1",
    "@tauri-apps/plugin-updater": "2.10.1",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/xterm": "6.0.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "diff": "9.0.0",
    "tailwind-merge": "3.6.0",
    "yaml": "2.9.0",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@codspeed/vitest-plugin": "^5.7.1",
    "@fontsource-variable/geist-mono": "^5.3.0",
    "@sveltejs/vite-plugin-svelte": "7.2.0",
    "@tailwindcss/vite": "4.3.3",
    "@tauri-apps/cli": "2.11.4",
    "@types/bun": "1.3.14",
    "@wdio/cli": "9.29.1",
    "@wdio/globals": "9.29.1",
    "@wdio/local-runner": "9.29.1",
    "@wdio/mocha-framework": "9.29.1",
    "@wdio/spec-reporter": "9.29.1",
    "@wdio/tauri-service": "1.2.0",
    "@xyflow/svelte": "1.6.2",
    "bits-ui": "2.18.1",
    "fast-check": "4.9.0",
    "lucide-svelte": "1.0.1",
    "svelte": "5.56.7",
    "svelte-check": "4.7.3",
    "tailwindcss": "4.3.3",
    "tw-animate-css": "1.4.0",
    "typescript": "7.0.2",
    "typescript-6": "npm:typescript@6.0.3",
    "vite": "8.1.5",
    "vitest": "^4.1.10",
    "webdriverio": "9.29.1"
  },
  "overrides": {
    "@codemirror/state": "6.7.1",
    "@codemirror/view": "6.43.6",
    "@wdio/native-utils": "2.5.0"
  }
}
